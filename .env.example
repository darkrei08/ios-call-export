# Backup encryption passphrase (set directly or use 1Password below)
# BACKUP_PASSPHRASE=your-backup-passphrase

# 1Password secret reference (triggers biometric prompt via `op` CLI)
# OP_BACKUP_REF=op://YourVault/iPhone Backup/password

# Webhook URL for Google Calendar sync
# WEBHOOK_URL=https://your-instance.com/webhook/your-webhook-path
